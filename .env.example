# Telegram Bot (from @BotFather)
TELEGRAM_BOT_TOKEN=your_bot_token_here

# Telegram OIDC (from @BotFather > Bot Settings > Web Login)
TELEGRAM_CLIENT_ID=your_bot_id_here
TELEGRAM_CLIENT_SECRET=your_client_secret_here

# App Config
APP_URL=http://localhost:3000
PORT=3000

# Session Secret
SESSION_SECRET=your_super_secret_session_key_change_this
